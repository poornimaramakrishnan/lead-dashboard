# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Email (Resend)
RESEND_API_KEY=re_xxxxx
NOTIFICATION_EMAIL=your-email@example.com

# Source Kill Switches (set to false to disable)
MIAMI_DADE_DERM_ACTIVE=true
FORT_LAUDERDALE_ACTIVE=true
CITY_OF_MIAMI_ACTIVE=true

# Schedule (24-hour format, local time)
SCHEDULE_HOUR=6
SCHEDULE_MINUTE=0

# Lookback days for initial seed run
INITIAL_LOOKBACK_DAYS=90
